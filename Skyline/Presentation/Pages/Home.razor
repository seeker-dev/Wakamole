@using Skyline.Application.DTOs
@using Skyline.Application.Interfaces
@using Skyline.Core.DTOs
@using Skyline.Presentation.DTOs

@inject IBlueskyService BlueskyService
@inject IModerationService ModerationService
@inject NavigationManager NavigationManager

@page "/"

@if (_feeds != null && _feeds.Any())
{

    <InfiniteScrolling ItemsProvider="GetItems">
        <ItemTemplate Context="item">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Secondary">?</MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@item.AuthorName || @item.AuthorHandle</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                @if (item.IsInViolation)
                {
                    <MudText Color="Color.Error">This post has been flagged for violating profile name or description rules.</MudText>
                }
                else
                {
                    <MudCardContent>
                        <MudText>@item.Content</MudText>
                    </MudCardContent>

                    @if (item.EmbeddedImages?.Any() == true)
                    {
                        <div class="d-flex flex-wrap gap-2 px-4 pb-2">
                            @foreach (var img in item.EmbeddedImages)
                            {
                                <img src="@img.fullsize" alt="@img.alt" style="max-width:100%; border-radius:4px;" />
                            }
                        </div>
                    }
                    @if (item.EmbeddedVideos?.Any() == true)
                    {
                        <div class="px-4 pb-2">
                            @foreach (var video in item.EmbeddedVideos)
                            {
                                <video controls poster="@video.thunbnail" style="max-width:100%; border-radius:4px;">
                                    <source src="@video.playlist" type="application/x-mpegURL" />
                                </video>
                            }
                        </div>
                    }
                }
            </MudCard>
        </ItemTemplate>
        <LoadingTemplate>
            <div>Loading...</div>
        </LoadingTemplate>
    </InfiniteScrolling>
}
else
{
    <p>No posts available.</p>
}


@code {

    private List<FeedDto> _feeds;
    private string _latestCursor;
    private int count;

    protected override async Task OnInitializedAsync()
    {
        if (!BlueskyService.IsLoggedIn)
        {    
            NavigationManager.NavigateTo("/login");
            return;
        }

        var feeds = await BlueskyService.ListUsersFeedsAsync();
        _feeds = feeds.ToList();
    }

    async Task<IEnumerable<PostDto>> GetItems(InfiniteScrollingItemsProviderRequest request)
    {
        if (_feeds == null || !_feeds.Any())
        {
            return Enumerable.Empty<PostDto>();
        }

        PagedResult<PostDto> posts = new PagedResult<PostDto>();
        int retry = 5;
        while (posts == null || posts.Items?.Any() == false)
        {
            posts = await BlueskyService.GetFeedPostsAsync(_feeds[0].Url, cursor: _latestCursor);
            _latestCursor = posts.NextPageToken;

            if (--retry <= 0)
            {
                break;
            }
        }

        foreach (var post in posts.Items.ToList())
        {
            if (await ModerationService.IsProfileNameInViolation(post.AuthorName) ||
                await ModerationService.IsProfileDescriptionInViolation(post.AuthorDescription))
            {
                await ModerationService.MarkPostAsViolationAsync(post);
            }
        }


        count += posts.Items?.Count() ?? 0;
        return posts.Items ?? Enumerable.Empty<PostDto>();
    }
}
